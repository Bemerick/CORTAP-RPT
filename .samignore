# SAM Build Ignore
# Exclude unnecessary files from Lambda deployment package

# Development files
.vscode/
.idea/
.bmad-ephemeral/
*.pyc
__pycache__/
.pytest_cache/
.coverage
*.log

# Documentation (not needed for Lambda - 8.3MB)
# All runtime assets have been migrated:
#   - Schema: docs/schemas/ → app/schemas/
#   - Templates: already in app/templates/
#   - Config: already in config/
docs/**
docs/

# Test files
tests/
scripts/test_*.py
scripts/manage_project_config.py

# Git
.git/
.gitignore

# Environment
.env
.env.*
venv/
env/
*.local

# Output directories
output/
.aws-sam/

# Session status files
*-STATUS*.md
RESUME*.md
SESSION*.md
TESTING*.md

# Keep these for deployment:
# config/ - INCLUDE (project setup configuration)
# app/templates/ - INCLUDE (Word templates)
# src/ - INCLUDE (mapping module)
